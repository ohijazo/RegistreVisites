# Base de dades (nova BD al PostgreSQL existent)
DATABASE_URL=postgresql+asyncpg://visites_user:PASSWORD@localhost/visites_db

# Clau de xifrat per al DNI (AES-256-GCM, 32 bytes en base64)
# Generar: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=

# Clau per a sessions del visitant i CSRF (cadena aleatòria llarga)
# Generar: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=canvia-aquesta-clau-secreta

# Clau independent per signar JWTs d'admin (HA DE SER DIFERENT de SECRET_KEY en producció)
# Generar: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# Pebre per a HMAC-SHA256 del DNI (cerca de visitants repetits sense desxifrar).
# Sense aquesta clau, un dump de la BD no permet correlacionar DNIs coneguts.
# Generar: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
LOOKUP_PEPPER=

# IPs autoritzades del quiosc (CSV). El lookup de visitants i el checkout
# per DNI només funcionen des d'aquestes IPs (en producció).
# Exemple: KIOSK_IP_ALLOWLIST=192.168.1.50,192.168.1.51
KIOSK_IP_ALLOWLIST=

# Secret compartit que la tablet de quiosc ha d'enviar al header X-Kiosk-Secret
# per als endpoints restringits. Defensa addicional a la IP allowlist.
# Generar: python -c "import secrets; print(secrets.token_urlsafe(32))"
KIOSK_SHARED_SECRET=

# Durada sessió admin en hores
SESSION_HOURS=8

# Durada màxima del token de sortida QR en hores
EXIT_TOKEN_HOURS=8

# Segons d'inactivitat a la tablet fins al reset automàtic
KIOSK_RESET_SECONDS=30

# Hores màximes de visita abans d'alertar (groc/vermell al dashboard)
MAX_VISIT_HOURS_WARN=4
MAX_VISIT_HOURS_ALERT=8

# Hores després de l'entrada perquè l'auto-checkout nocturn tanqui visites
# obertes (visitants que han marxat sense registrar la sortida).
AUTO_CLOSE_AFTER_HOURS=12

# Nom i adreça de l'empresa (apareix als textos legals)
COMPANY_NAME=La Meva Empresa
COMPANY_ADDRESS=Carrer Principal 1, 08001 Barcelona
COMPANY_EMAIL=dpo@empresa.com

# URL base de l'aplicació (per als QR de sortida)
BASE_URL=http://visites.empresa.local

# Backend d'enviament de mails: 'smtp' (clàssic) o 'graph_ms' (Microsoft 365).
# Per a comptes M365, usar 'graph_ms' és la opció recomanada (SMTP AUTH està
# en deprecació). Cal registrar una app a Entra ID amb permís Mail.Send.
EMAIL_BACKEND=smtp

# SMTP clàssic (cal si EMAIL_BACKEND=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=visites@empresa.com

# Microsoft Graph API (cal si EMAIL_BACKEND=graph_ms)
# Es configura amb una app registrada a Entra ID amb permís d'aplicació
# Mail.Send, restringida a la bústia desitjada via Application Access Policy.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_SENDER_EMAIL=

# Destinataris per defecte de la notificació automàtica quan es crea una
# visita prevista (separats per comes). Camp buit = no s'envia automàticament.
# L'usuari pot afegir-ne més o desactivar-ho per cada visita al formulari.
# Exemple: EXPECTED_NOTIFY_RECIPIENTS=cap@empresa.com,recepcio@empresa.com
EXPECTED_NOTIFY_RECIPIENTS=

# Entorn
ENV=development
DEBUG=true
